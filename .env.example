# =============================================================================
# Unforgetting — Environment Variables
# =============================================================================
# For Docker: hostnames "db" and "redis" refer to Docker Compose service names.
# Copy this file to .env and fill in your API keys.
# =============================================================================

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true

# Database (PostgreSQL via Docker)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=unforgetting
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# LLM (openrouter | anthropic | openai)
LLM_PROVIDER=openrouter
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Transcription (Deepgram — swap URL for other STT providers)
TRANSCRIPTION_API_URL=https://api.deepgram.com/v1/listen
TRANSCRIPTION_API_KEY=your-deepgram-key-here
TRANSCRIPTION_MODEL=nova-3
TRANSCRIPTION_LANGUAGE=en
